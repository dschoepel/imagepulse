# Server
PORT=3000
NODE_ENV=development

# Database
DB_PATH=./data/imagepulse.db

# ntfy notifications
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=imagepulse
NTFY_TOKEN=

# Email notifications (nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=imagepulse@example.com
EMAIL_TO=

# GitHub (for fetching release notes)
GITHUB_TOKEN=

# Event retention (days, 0 = keep forever)
RETENTION_DAYS=90
