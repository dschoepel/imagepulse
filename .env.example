# ─────────────────────────────────────────────────────────────────
# ImagePulse — environment configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────
# Port the app listens on inside the container.
# Must match the container-side port in docker-compose.yml.
PORT=3579
NODE_ENV=production

# ── Container identity ────────────────────────────────────────────
# Run the container as a specific user so files written to ./data
# are owned by your host user rather than root.
# Find your values by running: id
PUID=1000
PGID=1000

# ── Timezone ──────────────────────────────────────────────────────
# Sets the container clock. Affects timestamps in logs and the DB.
# Examples: America/New_York  America/Chicago  Europe/London  UTC
TZ=UTC

# ── Database ──────────────────────────────────────────────────────
DB_PATH=./data/imagepulse.db

# ── ntfy notifications ────────────────────────────────────────────
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=imagepulse
NTFY_TOKEN=

# ── Email notifications (SMTP) ────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=imagepulse@example.com
EMAIL_TO=

# ── GitHub (release notes) ────────────────────────────────────────
# Personal access token — increases rate limit from 60 to 5000 req/hr.
# Needs no scopes for public repos; needs repo scope for private repos.
GITHUB_TOKEN=

# ── Event retention ───────────────────────────────────────────────
# Days to keep events before pruning. 0 = keep forever.
RETENTION_DAYS=90
